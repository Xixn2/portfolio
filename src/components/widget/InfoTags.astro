---

import WidgetLayout from './WidgetLayout.astro'

const tags = [{}]

const COLLAPSED_HEIGHT = '7.5rem'

const isCollapsed = tags.length >= 20

interface Props {
  class?: string
  style?: string
}
const className = Astro.props.class
const style = Astro.props.style
---
<WidgetLayout name={"Info"} id="tags" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT} class={className} style={style}>
    <div class="flex flex-wrap font-bold dark:text-[#ffffff]">
        <p>2007.08.02</p>
        <p>광주소프트웨어마이스터고</p>
    </div>
</WidgetLayout>